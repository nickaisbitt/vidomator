# Vidomator Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git

# --- Render Service ---
PORT=3000
FILES_BASE_PATH=/files
NODE_ENV=production

# Speechify TTS
SPEECHIFY_API_KEY=

# OpenRouter (LLM + AI Image Generation)
OPENROUTER_API_KEY=

# Stock Footage
PEXELS_API_KEY=
PIXABAY_API_KEY=

# BytePlus / Seedance AI Video
BYTEPLUS_ACCESS_KEY=
BYTEPLUS_SECRET_KEY=

# OAuth redirect URI for YouTube publishing
# Set to your Railway render-service public URL + /oauth2callback
# Example: https://render-service-production-xxxx.up.railway.app/oauth2callback
OAUTH_REDIRECT_URI=

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=
N8N_ENCRYPTION_KEY=
N8N_HOST=
N8N_PROTOCOL=https
WEBHOOK_URL=
GENERIC_TIMEZONE=UTC
EXECUTIONS_MODE=regular
EXECUTIONS_TIMEOUT=300
EXECUTIONS_TIMEOUT_MAX=3600
NODE_FUNCTION_ALLOW_EXTERNAL=moment,lodash,axios
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
N8N_BINARY_DATA_STORAGE=/files/binary

# --- YouTube ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=