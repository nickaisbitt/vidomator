{
  "name": "vidomator-render-service",
  "version": "2.0.0-SCORCHED-EARTH",
  "description": "FFmpeg video assembly service for The Update Desk",
  "main": "dist/server.js",
  "scripts": {
    "prebuild": "rm -rf dist && mkdir -p dist",
    "build": "tsc",
    "start": "node dist/engine.js",
    "dev": "ts-node-dev --respawn --transpile-only src/engine.ts",
    "test": "jest",
    "version-probe": "echo 'Vidomator v2.0.0-SCORCHED-EARTH-ENGINE'"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2",
    "google-tts-api": "^2.0.2",
    "googleapis": "^171.4.0",
    "multer": "^1.4.5-lts.1",
    "puppeteer": "^21.6.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
